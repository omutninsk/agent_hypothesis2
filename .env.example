# LLM provider (OpenAI-compatible API)
LLM_API_KEY=your-llm-api-key-here
LLM_BASE_URL=https://aisupervisor.ru/v1
LLM_MODEL=qwen3_4b_instruct

# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_ALLOWED_USER_IDS=[]

# PostgreSQL (overridden by docker-compose for container networking)
POSTGRES_DSN=postgresql://agent:agent@postgres:5432/agent_db

# Docker sandbox
DOCKER_SANDBOX_IMAGE=agent-sandbox:latest
DOCKER_EXECUTION_TIMEOUT=60

# Logging
LOG_LEVEL=INFO
