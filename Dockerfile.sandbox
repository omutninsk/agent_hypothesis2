FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    bash curl git build-essential \
    # Chromium deps for Playwright
    libnss3 libnspr4 libdbus-1-3 libatk1.0-0 libatk-bridge2.0-0 \
    libcups2 libdrm2 libxcomposite1 libxdamage1 libxrandr2 \
    libgbm1 libpango-1.0-0 libcairo2 libasound2 libxshmfence1 \
    libx11-xcb1 fonts-liberation \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir \
    pandas numpy matplotlib seaborn \
    requests beautifulsoup4 \
    pyyaml toml \
    scipy scikit-learn \
    Pillow \
    openpyxl xlrd \
    ddgs \
    lxml \
    pdfplumber \
    playwright

# Download Chromium to a global path accessible by the sandbox user
ENV PLAYWRIGHT_BROWSERS_PATH=/opt/pw-browsers
RUN playwright install chromium

RUN useradd -m -s /bin/bash sandbox
USER sandbox
ENV PLAYWRIGHT_BROWSERS_PATH=/opt/pw-browsers
WORKDIR /workspace
